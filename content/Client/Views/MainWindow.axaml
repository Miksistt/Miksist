<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.ViewModels"
        x:Class="Client.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Управление товарами" Width="700" Height="450">
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="2*,1*" Margin="10">

        <DataGrid Grid.Row="0" Grid.Column="0"
                  Items="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="True"
                  Margin="0,0,10,0" />

        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="8">
            <TextBlock Text="Название" />
            <TextBox Text="{Binding Name}" />
            <TextBlock Text="Цена" />
            <TextBox Text="{Binding Price}" />
            <TextBlock Text="Количество" />
            <TextBox Text="{Binding Quantity}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="Добавить" Command="{Binding AddCommand}" />
            <Button Content="Изменить" Command="{Binding UpdateCommand}" />
            <Button Content="Удалить" Command="{Binding DeleteCommand}" />
        </StackPanel>

    </Grid>
</Window>
